{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://autonomous-sdd.local/result.schema.json",
  "type": "object",
  "required": [
    "status",
    "summary",
    "files_read",
    "files_changed",
    "commands_run",
    "tests",
    "deviations",
    "blocking_reason",
    "task_id",
    "requirement_evidence",
    "residual_risks"
  ],
  "properties": {
    "status": {"enum": ["completed", "failed", "blocked"]},
    "summary": {"type": "string"},
    "files_read": {"type": "array", "items": {"type": "string"}},
    "files_changed": {"type": "array", "items": {"type": "string"}},
    "commands_run": {
      "type": "array",
      "items": {"type": "array", "minItems": 1, "items": {"type": "string"}}
    },
    "tests": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["command", "exit_code"],
        "properties": {
          "command": {"type": "array", "minItems": 1, "items": {"type": "string"}},
          "exit_code": {"type": "integer"}
        },
        "additionalProperties": false
      }
    },
    "deviations": {"type": "array", "items": {"type": "string"}},
    "blocking_reason": {"type": ["string", "null"]},
    "task_id": {"type": ["string", "null"], "pattern": "^\\d+\\.\\d+$"},
    "requirement_evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["requirement", "implementation_files", "test_files", "status"],
        "properties": {
          "requirement": {"type": "string", "minLength": 1},
          "implementation_files": {"type": "array", "items": {"type": "string"}},
          "test_files": {"type": "array", "items": {"type": "string"}},
          "status": {"enum": ["satisfied", "partial", "not_satisfied"]}
        },
        "additionalProperties": false
      }
    },
    "residual_risks": {"type": "array", "items": {"type": "string"}}
  },
  "additionalProperties": false
}
